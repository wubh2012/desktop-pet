{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite/client", "vitest/globals"],
    "noEmit": true
  },
  "include": ["src/renderer/**/*.ts"]
}
